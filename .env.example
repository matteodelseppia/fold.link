# Local development environment variables for fold.link.
#
# Copy this file to `.env` (already excluded by .gitignore — `.env` and
# `.env.*` are ignored except this example) and load it into your shell
# before starting the app, e.g.:
#
#   set -a && source .env && set +a
#   ./gradlew bootRun
#
# These are LOCAL-ONLY fixture values. They point at the Compose Redis
# service (see docker-compose.yml — bound to 127.0.0.1:6379, so nothing
# here can resolve to a staging or production host) and use the "local"
# Spring profile's own safe defaults where possible. They are not secrets
# and grant no access to any hosted environment.
#
# Real staging/production values are never committed here or anywhere else
# in this repository — they are stored in Infisical and injected into the
# runtime environment at deploy time (see
# docs/milestones/mvp/tickets/MVP-032-define-infisical-secret-schema.md and
# docs/milestones/mvp/tickets/MVP-038-document-secret-bootstrap-boundary.md).

# --- Spring profile ---
SPRING_PROFILES_ACTIVE=local

# --- Redis (matches docker-compose.yml's redis service) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false

# --- Application (link.fold.config.AppProperties) ---
APP_BASE_URL=http://localhost:8080
APP_ALIAS_LENGTH=8
APP_ALIAS_RETRY_COUNT=5
APP_REDIS_KEY_PREFIX=v1:link:

# --- Server / actuator / logging ---
# Only the health endpoint (and its liveness/readiness sub-paths) is ever
# web-exposed; this is not independently configurable per environment.
SERVER_PORT=8080
ACTUATOR_HEALTH_SHOW_DETAILS=always
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
